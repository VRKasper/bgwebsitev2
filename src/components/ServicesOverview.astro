---
const services = [
  {
    name: "Vaccinaties",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 2 4 4"/><path d="m17 7 3-3"/><path d="M19 9 8.7 19.3c-1 1-2.5 1-3.4 0l-.6-.6c-1-1-1-2.5 0-3.4L15 5"/><path d="m9 11 4 4"/><path d="m5 19-3 3"/><path d="m14 4 6 6"/></svg>`,
  },
  {
    name: "Consultaties",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20a6 6 0 0 0-12 0"/><circle cx="12" cy="10" r="4"/><path d="M21.8 16c.2-1 .2-2 0-3"/><path d="M22 12c0-5.5-4.5-10-10-10S2 6.5 2 12"/></svg>`,
  },
  {
    name: "Dieet",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 20h10"/><path d="M10 20c5.5-2.5.8-6.4 3-10"/><path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/><path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/></svg>`,
  },
  {
    name: "Radiografie",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 12h10"/><path d="M12 7v10"/><circle cx="12" cy="12" r="3"/></svg>`,
  },
  {
    name: "Voeding en verzorging",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12a5 5 0 0 0 5-5c0-2-1-3.5-2-4.5"/><path d="M8 2c-1 1-2 2.5-2 4.5a5 5 0 0 0 5 5"/><path d="M2 22h20"/><path d="M7 15a7 7 0 0 0 10 0"/><path d="M12 12v3"/></svg>`,
  },
  {
    name: "Chirurgie",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><path d="M8.12 8.12 12 12"/><path d="M20 4 8.12 15.88"/><circle cx="6" cy="18" r="3"/><path d="M14.8 14.8 20 20"/></svg>`,
  },
];
---

<section class="py-16 bg-white" aria-label="Overzicht diensten">
  <div class="max-w-[1100px] mx-auto px-8">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-8">
      {
        services.map((service) => (
          <div class="flex flex-col items-center text-center gap-4 group">
            <div
              class="text-primary transition-transform duration-300 group-hover:scale-110"
              set:html={service.icon}
            />
            <span class="text-[0.95rem] font-semibold text-dark leading-tight">
              {service.name}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
