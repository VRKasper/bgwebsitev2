---
import { Image } from "astro:assets";
import headerLogoImg from "../assets/graphics/logo-transparant.png";
---

<header
  class="fixed top-0 left-0 w-full z-50 bg-white shadow-sm transition-all duration-300 site-header"
  id="top"
>
  <div
    class="top-bar bg-primary-dark text-white text-xs py-1.5 px-8 hidden md:block transition-all duration-300"
  >
    <div class="max-w-[1200px] mx-auto flex justify-end gap-6">
      <a
        href="tel:+32476330384"
        class="flex items-center gap-1.5 hover:opacity-80 transition-opacity"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-3.5 h-3.5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
          ></path></svg
        >
        0476 33 03 84
      </a>
      <a
        href="https://maps.google.com/?q=Palingsgatstraat+58,+9111+Belsele"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 hover:opacity-80 transition-opacity"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-3.5 h-3.5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
          ></path><circle cx="12" cy="10" r="3"></circle></svg
        >
        Palingsgatstraat 58, 9111 Belsele
      </a>
    </div>
  </div>
  <div class="px-8 py-4 transition-all duration-300 header-main">
    <div class="max-w-[1200px] mx-auto flex items-center gap-8">
      <a
        href="/"
        class="flex items-center gap-3"
        aria-label="Beestig Gezond - Home"
      >
        <Image
          src={headerLogoImg}
          alt="Beestig Gezond logo"
          height={50}
          class="h-[50px] w-auto"
        />
        <div class="leading-none">
          <span class="block text-xs leading-none tracking-wide text-text-light"
            >Dierenartsenpraktijk</span
          >
          <span class="block text-lg leading-tight font-display text-dark"
            >Beestig Gezond</span
          >
          <span
            class="block text-xs leading-tight tracking-wide text-text-light"
            >Helena Brône en Elisabeth Bonte</span
          >
        </div>
      </a>
      <nav class="main-nav ml-auto" aria-label="Hoofdnavigatie">
        <ul class="list-none flex gap-8">
          <li>
            <a
              href="#afspraak"
              class="font-semibold text-[0.95rem] tracking-tight text-dark relative transition-colors duration-200 hover:text-primary nav-link"
              >Afspraak</a
            >
          </li>
          <li>
            <a
              href="#diensten"
              class="font-semibold text-[0.95rem] tracking-tight text-dark relative transition-colors duration-200 hover:text-primary nav-link"
              >Diensten</a
            >
          </li>
          <li>
            <a
              href="#werkwijze"
              class="font-semibold text-[0.95rem] tracking-tight text-dark relative transition-colors duration-200 hover:text-primary nav-link"
              >Werkwijze</a
            >
          </li>
          <li>
            <a
              href="#contact"
              class="font-semibold text-[0.95rem] tracking-tight text-dark relative transition-colors duration-200 hover:text-primary nav-link"
              >Contact</a
            >
          </li>
        </ul>
        <div
          class="mobile-contact hidden flex-col gap-3 mt-8 pt-6 border-t border-border"
        >
          <a
            href="tel:+32476330384"
            class="flex items-center gap-2 text-sm text-text-light hover:text-primary transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
              ></path></svg
            >
            0476 33 03 84
          </a>
          <a
            href="https://maps.google.com/?q=Palingsgatstraat+58,+9111+Belsele"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-sm text-text-light hover:text-primary transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
              ></path><circle cx="12" cy="10" r="3"></circle></svg
            >
            Palingsgatstraat 58, 9111 Belsele
          </a>
        </div>
      </nav>
      <a
        href="#afspraak"
        class="hidden md:inline-block bg-primary text-white! font-bold rounded-full px-5 py-2.5 text-sm transition-all duration-200 hover:bg-primary-dark hover:-translate-y-0.5 hover:shadow-lg"
        >Maak een afspraak</a
      >
      <button
        class="mobile-toggle hidden md:hidden flex-col gap-[5px] p-1 bg-transparent border-none cursor-pointer"
        aria-label="Menu openen"
        aria-expanded="false"
      >
        <span
          class="block w-6 h-0.5 bg-dark rounded-sm transition-all duration-300"
        ></span>
        <span
          class="block w-6 h-0.5 bg-dark rounded-sm transition-all duration-300"
        ></span>
        <span
          class="block w-6 h-0.5 bg-dark rounded-sm transition-all duration-300"
        ></span>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector(".mobile-toggle");
  const nav = document.querySelector(".main-nav");
  if (toggle && nav) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      nav.classList.toggle("is-open");
      toggle.classList.toggle("is-active");
    });
    nav.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        nav.classList.remove("is-open");
        toggle.classList.remove("is-active");
        toggle.setAttribute("aria-expanded", "false");
      });
    });
  }

  // Sticky header
  const header = document.querySelector(".site-header");
  if (header) {
    window.addEventListener("scroll", () => {
      header.classList.toggle("is-scrolled", window.scrollY > 60);
    });
  }
</script>

<style>
  /* Nav link underline animation */
  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-primary);
    transition: width 0.3s;
  }
  .nav-link:hover::after {
    width: 100%;
  }

  /* JS toggle states */
  .site-header.is-scrolled {
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.1);
  }
  .site-header.is-scrolled .top-bar {
    max-height: 0;
    padding-top: 0;
    padding-bottom: 0;
    overflow: hidden;
  }
  .site-header.is-scrolled .header-main {
    padding-top: 0.6rem;
    padding-bottom: 0.6rem;
  }
  .mobile-toggle.is-active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .mobile-toggle.is-active span:nth-child(2) {
    opacity: 0;
  }
  .mobile-toggle.is-active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile nav drawer */
  @media (max-width: 768px) {
    .mobile-toggle {
      display: flex !important;
    }
    .main-nav {
      position: fixed;
      top: 0;
      right: -100%;
      width: 280px;
      height: 100vh;
      background: #fff;
      box-shadow: -4px 0 30px rgba(0, 0, 0, 0.1);
      transition: right 0.35s ease;
      padding: 5rem 2rem 2rem;
      margin-left: 0;
    }
    .main-nav.is-open {
      right: 0;
    }
    .main-nav ul {
      flex-direction: column;
      gap: 1.5rem;
    }
    .main-nav a {
      font-size: 1.1rem;
    }
    .mobile-contact {
      display: flex !important;
    }
  }
</style>
