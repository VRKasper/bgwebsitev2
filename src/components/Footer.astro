---
import { Image } from "astro:assets";
import logoImg from "../assets/graphics/logo-white.png";
---

<footer class="bg-dark text-white/80 pt-16">
  <div
    class="max-w-[1100px] mx-auto px-8 grid grid-cols-1 lg:grid-cols-[1.4fr_1fr_1fr] gap-12 pb-12 border-b border-white/[0.08] max-lg:text-center"
  >
    <div>
      <Image
        src={logoImg}
        alt="Logo Beestig Gezond - Dierenartsenpraktijk Belsele"
        width={90}
        height={105}
        loading="lazy"
        class="mb-4 h-[100px] w-auto max-lg:mx-auto"
      />
      <p class="text-sm leading-[1.7]">
        Dierenartsenpraktijk gelegen in Belsele.<br />Gespecialiseerd in kleine
        huisdieren.
      </p>
    </div>
    <div>
      <p class="font-display text-white text-[1.05rem] mb-4">Navigatie</p>
      <ul class="list-none space-y-2">
        <li>
          <a
            href="#afspraak"
            class="text-sm transition-colors duration-200 hover:text-primary"
            >Afspraak maken</a
          >
        </li>
        <li>
          <a
            href="#diensten"
            class="text-sm transition-colors duration-200 hover:text-primary"
            >Diensten</a
          >
        </li>
        <li>
          <a
            href="#werkwijze"
            class="text-sm transition-colors duration-200 hover:text-primary"
            >Werkwijze</a
          >
        </li>
        <li>
          <a
            href="#contact"
            class="text-sm transition-colors duration-200 hover:text-primary"
            >Contact</a
          >
        </li>
      </ul>
    </div>
    <div>
      <p class="font-display text-white text-[1.05rem] mb-4">Contact</p>
      <ul class="list-none space-y-2">
        <li>
          <a
            href="tel:+32476330384"
            class="text-sm transition-colors duration-200 hover:text-primary"
            >0476 33 03 84</a
          >
        </li>
        <li>
          <a
            href="mailto:info@beestiggezond.be"
            class="text-sm transition-colors duration-200 hover:text-primary"
            >info@beestiggezond.be</a
          >
        </li>
        <li>
          <a
            href="https://maps.google.com/?q=Palingsgatstraat+58,+9111+Belsele"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm transition-colors duration-200 hover:text-primary"
            >Palingsgatstraat 58, 9111 Belsele</a
          >
        </li>
      </ul>
      <p class="font-display text-white text-[1.05rem] mb-4 mt-6">
        Openingsuren
      </p>
      <p class="text-sm mt-2">
        Ma – Vr: 9.00 – 18.30<br />Weekend: wachtdienst
      </p>
    </div>
  </div>
  <div class="text-center py-6 px-8 text-xs text-white/70">
    <p>
      &copy; {new Date().getFullYear()} Beestig Gezond. Alle rechten voorbehouden.
    </p>
  </div>
</footer>
